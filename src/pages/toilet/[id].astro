---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.jsx';
import ReviewSection from '../../components/ReviewSection.jsx';
import { Star, Navigation, ShieldCheck, Accessibility, Clock, MapPin } from 'lucide-react';

export function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
    { params: { id: '4' } }
  ];
}

const { id } = Astro.params;

// Mock data fetcher based on ID
const toilets = {
  '1': {
    name: 'Nhà vệ sinh Công viên Tao Đàn',
    image: 'https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=1200',
    rating: 4.5,
    distance: 0.8,
    cleanliness: 4,
    isFree: true,
    hasAccessible: true,
    address: 'Đường Nguyễn Thị Minh Khai, Quận 1, TP.HCM',
    openTime: '05:00 - 22:00',
    reviews: [
      { user: 'Nguyễn Văn A', rating: 5, date: '02/07/2026', comment: 'Rất sạch sẽ, có giấy vệ sinh và nước rửa tay đầy đủ.' },
      { user: 'Trần B', rating: 4, date: '30/06/2026', comment: 'Hơi đông vào buổi sáng cuối tuần nhưng nhìn chung ổn.' }
    ]
  },
  '2': {
    name: 'WC Phố đi bộ Nguyễn Huệ',
    image: 'https://images.unsplash.com/photo-1563212001-9252062547b7?auto=format&fit=crop&q=80&w=1200',
    rating: 4.8,
    distance: 1.2,
    cleanliness: 5,
    isFree: false,
    hasAccessible: true,
    address: 'Phố đi bộ Nguyễn Huệ, Quận 1, TP.HCM',
    openTime: '24/7',
    reviews: [
      { user: 'Le C', rating: 5, date: '01/07/2026', comment: 'Thu phí 5k nhưng rất xứng đáng, thơm tho và hiện đại.' }
    ]
  },
  '3': {
    name: 'Trạm xăng Petrolimex Q3',
    image: 'https://images.unsplash.com/photo-1564500913959-1e35d1056555?auto=format&fit=crop&q=80&w=1200',
    rating: 3.5,
    distance: 2.1,
    cleanliness: 3,
    isFree: true,
    hasAccessible: false,
    address: 'Ngã tư CMT8 & Điện Biên Phủ, Quận 3',
    openTime: '24/7',
    reviews: [
      { user: 'User123', rating: 3, date: '25/06/2026', comment: 'Tạm chấp nhận được để chữa cháy.' },
      { user: 'Binh', rating: 4, date: '20/06/2026', comment: 'Nhân viên trạm xăng thân thiện, cho dùng free.' }
    ]
  },
  '4': {
    name: 'Nhà vệ sinh Takashimaya',
    image: 'https://images.unsplash.com/photo-1623126908029-58cb08a2b272?auto=format&fit=crop&q=80&w=1200',
    rating: 5.0,
    distance: 1.5,
    cleanliness: 5,
    isFree: true,
    hasAccessible: true,
    address: 'Tầng B2, Saigon Centre, 65 Lê Lợi, Quận 1',
    openTime: '09:30 - 22:00',
    reviews: [
      { user: 'Hương T', rating: 5, date: '04/07/2026', comment: 'Như khách sạn 5 sao. Không có gì để chê.' }
    ]
  }
};

const data = toilets[id] || toilets['1'];
---

<Layout>
  <Header client:load />
  
  <main class="container" style="padding-top: 2rem; padding-bottom: 5rem;">
    {/* Cover Image */}
    <div style={`width: 100%; height: 400px; border-radius: 24px; background: linear-gradient(to top, rgba(15, 23, 42, 0.9), transparent), url('${data.image}') center/cover no-repeat; position: relative; display: flex; align-items: flex-end; padding: 3rem; margin-bottom: 2rem;`}>
      {data.isFree && (
        <div style="position: absolute; top: 2rem; right: 2rem; background: var(--success); color: #fff; padding: 8px 16px; border-radius: 8px; font-weight: 700; font-size: 0.9rem;">
          MIỄN PHÍ
        </div>
      )}
      <div>
        <h1 style="font-size: 3.5rem; margin-bottom: 1rem; color: #fff;">{data.name}</h1>
        <div style="display: flex; gap: 2rem; color: var(--text-secondary); font-size: 1.1rem; align-items: center;">
          <span style="display: flex; align-items: center; gap: 0.5rem; color: var(--warning); font-weight: 600;">
            <Star fill="currentColor" size={20} /> {data.rating}
          </span>
          <span style="display: flex; align-items: center; gap: 0.5rem;">
            <MapPin size={18} /> {data.distance} km
          </span>
          <span style="display: flex; align-items: center; gap: 0.5rem;">
            <ShieldCheck size={18} color="var(--success)" /> Sạch sẽ: {data.cleanliness}/5
          </span>
        </div>
      </div>
    </div>

    {/* Content Grid */}
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 3rem;">
      {/* Main Info */}
      <div>
        <h3 style="font-size: 1.5rem; margin-bottom: 1.5rem; color: var(--text-primary);">Thông tin chung</h3>
        <p style="color: var(--text-secondary); display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; font-size: 1.1rem;">
          <MapPin size={20} color="var(--primary)" /> {data.address}
        </p>
        <p style="color: var(--text-secondary); display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; font-size: 1.1rem;">
          <Clock size={20} color="var(--primary)" /> Giờ mở cửa: {data.openTime}
        </p>
        {data.hasAccessible && (
          <p style="color: var(--text-secondary); display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; font-size: 1.1rem;">
            <Accessibility size={20} color="var(--primary)" /> Có lối đi/tiện ích cho người khuyết tật
          </p>
        )}

        <ReviewSection client:load reviews={data.reviews} />
      </div>

      {/* Sidebar */}
      <div>
        <div class="glass-panel" style="padding: 2rem; border-radius: 16px;">
          <h3 style="margin-bottom: 1.5rem; font-size: 1.25rem;">Chỉ đường</h3>
          <div style="width: 100%; height: 200px; background: var(--bg-tertiary); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); margin-bottom: 1.5rem;">
            [Bản đồ tĩnh]
          </div>
          <button style="width: 100%; padding: 1rem; background: var(--primary); color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 0.5rem;">
            <Navigation size={18} /> Mở Google Maps
          </button>
        </div>
      </div>
    </div>
  </main>
</Layout>
