---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.jsx';
import LoginForm from '../components/LoginForm.jsx';
---

<Layout>
  <Header client:load />
  
  <main style="position: relative; overflow: hidden;">
    {/* Background decoration */}
    <div style="position: absolute; top: -20%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(59,130,246,0.15) 0%, transparent 70%); border-radius: 50%; z-index: -1;"></div>
    <div style="position: absolute; bottom: -20%; right: -10%; width: 40vw; height: 40vw; background: radial-gradient(circle, rgba(16,185,129,0.1) 0%, transparent 70%); border-radius: 50%; z-index: -1;"></div>
    
    <div class="container">
      <LoginForm client:load />
    </div>
  </main>
</Layout>
